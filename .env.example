# Local-dev environment file. Copy to .env and fill in real values.
# .env is gitignored; .env.example is the template that ships with the repo.
# For docker --env-file, do NOT quote values.
#
# This file is for the `pam-approver (dev)` OAuth client whose Authorised
# JavaScript origins include http://localhost:8080. The production deployment
# uses a SEPARATE OAuth client (`pam-approver (prod)`) whose origins list does
# NOT include localhost. See README "OAuth client setup".

OAUTH_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# Comma-separated GCP project IDs to scan for entitlements you can approve.
PAM_PROJECTS=my-project-id,my-other-project-id

# Workspace domain: enforced as Google's `hd` OAuth hint and re-checked in
# the browser after sign-in. Leave empty to allow any Google account.
HOSTED_DOMAIN=example.com
